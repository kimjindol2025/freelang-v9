// ============================================
// 13. 유틸리티
// ============================================

// SQL Injection 방지 (값 이스케이프)
fn escape_string(value: str) -> str {
  var result = ""
  var i = 0

  while i < length(value) {
    var ch = substring(value, i, i + 1)

    if ch == "'" {
      result = result + "''"  // 단일 따옴표 escape
    } else if ch == "\"" {
      result = result + "\\\""  // 이중 따옴표 escape
    } else {
      result = result + ch
    }

    i = i + 1
  }

  return result
}

// 쿼리 최적화 제안
fn analyze_query_performance(sql: str) -> str {
  var suggestions = ""

  // SELECT * 사용 확인
  if find_substring(sql, "SELECT *") >= 0 {
    suggestions = suggestions + "- Avoid SELECT *\n"
  }

  // JOIN 없는 N+1 쿼리 확인
  if find_substring(sql, "WHERE id") >= 0 {
    suggestions = suggestions + "- Consider using JOIN\n"
  }

  return suggestions
}

// 부분 문자열 찾기
fn find_substring(str: str, substr: str) -> i32 {
  var i = 0

  while i <= length(str) - length(substr) {
    if substring(str, i, i + length(substr)) == substr {
      return i
    }
    i = i + 1
  }

  return -1
}
