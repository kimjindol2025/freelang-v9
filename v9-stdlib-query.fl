// 캐시에 쿼리 결과 저장
fn cache_query_result(query_key: str, result: any) -> void {
  query_cache[query_key] = result
}

// 캐시에서 쿼리 결과 조회
fn get_cached_result(query_key: str) -> any {
  return query_cache[query_key]
}

// 캐시 초기화
fn clear_query_cache() -> void {
  query_cache = {}
}

