{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "../dist",
    "rootDir": "../src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": ["../src/**/*"],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "../src/test-phase87-packages.ts",
    "../src/stdlib-server.ts",
    "../src/stdlib-ws.ts",
    "../src/stdlib-wsc.ts",
    "../src/stdlib-pg.ts",
    "../src/test-composition.ts",
    "../src/test-modules.ts",
    "../src/__tests__/reliability.test.ts"
  ]
}
