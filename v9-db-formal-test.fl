// v9 DB 정식 구현 통합 테스트
// 메모리 DB → 파일 저장 DB로 진화

fn test_1_save_and_load() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 1: 저장 및 로드                   ║")
    println("╚═══════════════════════════════════════════╝")

    ;; 데이터베이스 생성
    var table = table_new("users", [])
    table = table_insert(table, ["1", "Alice", "Seoul"])
    table = table_insert(table, ["2", "Bob", "Busan"])

    var db = database_new("production")
    db = database_add_table(db, table)

    println("✅ Database created: " + str(db.table_count) + " tables")

    ;; 저장
    var saved = database_save(db, "/tmp/prod.v9db")
    println("✅ Database saved")

    ;; 로드
    var loaded = database_load("/tmp/prod.v9db")
    println("✅ Database loaded")
    println("")
}

fn test_2_wal_logging() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 2: WAL 로깅                       ║")
    println("╚═══════════════════════════════════════════╝")

    var wal = wal_new()

    ;; INSERT 로깅
    wal = wal_append_insert(wal, "users", 1, ["1", "Alice"])
    wal = wal_append_insert(wal, "users", 2, ["2", "Bob"])

    ;; UPDATE 로깅
    wal = wal_append_update(wal, "users", 1, ["1", "Alice"], ["1", "Alice Kim"])

    ;; DELETE 로깅
    wal = wal_append_delete(wal, "users", 2, ["2", "Bob"])

    println("✅ WAL logging completed")
    println("   " + wal_stats(wal))
    println("")
}

fn test_3_checkpoint() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 3: 체크포인트                     ║")
    println("╚═══════════════════════════════════════════╝")

    var table = table_new("products", [])
    table = table_insert(table, ["P1", "Laptop"])
    table = table_insert(table, ["P2", "Mouse"])
    table = table_insert(table, ["P3", "Keyboard"])

    var db = database_new("shop")
    db = database_add_table(db, table)

    ;; 체크포인트 생성
    var checkpoint = create_checkpoint(db, "/tmp/shop.checkpoint")
    println("✅ Checkpoint created")

    ;; 체크포인트 복원
    var restored = restore_from_checkpoint("/tmp/shop.checkpoint")
    println("✅ Checkpoint restored")
    println("")
}

fn test_4_wal_replay() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 4: WAL 재생                       ║")
    println("╚═══════════════════════════════════════════╝")

    ;; 기본 DB
    var db = database_new("app")

    ;; WAL 생성
    var wal = wal_new()
    wal = wal_append_insert(wal, "users", 1, ["1", "Charlie"])
    wal = wal_append_insert(wal, "users", 2, ["2", "David"])
    wal = wal_append_update(wal, "users", 1, ["1", "Charlie"], ["1", "Charles"])

    ;; WAL 재생
    println("[REPLAY] Replaying " + str(wal.entry_count) + " WAL entries...")
    db = replay_wal_entries(db, wal)

    println("✅ WAL replay completed")
    println("")
}

fn test_5_integrity_check() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 5: 무결성 검사                    ║")
    println("╚═══════════════════════════════════════════╝")

    ;; 올바른 데이터
    var col1 = Column {
        name: "id",
        data_type: "integer",
        nullable: false,
        primary_key: true
    }
    var col2 = Column {
        name: "name",
        data_type: "string",
        nullable: false,
        primary_key: false
    }

    var cols: [Column] = []
    cols.push(col1)
    cols.push(col2)

    var table = Table {
        name: "valid_table",
        columns: cols,
        rows: [],
        row_count: 0,
        next_id: 1
    }

    table = table_insert(table, ["1", "Test"])

    var db = database_new("test")
    db = database_add_table(db, table)

    ;; 무결성 검사
    var integrity = check_database_integrity(db)

    if integrity.is_valid {
        println("✅ Database integrity check passed")
    } else {
        println("⚠️ Database has issues: " + str(length(integrity.issues)))
    }

    println("")
}

fn test_6_backup_restore() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 6: 백업 및 복원                   ║")
    println("╚═══════════════════════════════════════════╝")

    ;; 데이터 생성
    var table = table_new("orders", [])
    table = table_insert(table, ["O1", "Order1"])
    table = table_insert(table, ["O2", "Order2"])
    table = table_insert(table, ["O3", "Order3"])

    var db = database_new("ecommerce")
    db = database_add_table(db, table)

    ;; 백업
    var backup_ok = create_backup(db, "/tmp/ecommerce.backup")
    println("✅ Backup created")

    ;; 복원
    var restored = restore_backup("/tmp/ecommerce.backup")
    println("✅ Backup restored")
    println("")
}

fn test_7_recovery_procedure() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 7: 복구 절차                      ║")
    println("╚═══════════════════════════════════════════╝")

    ;; 정상 종료 확인
    var is_clean = is_database_clean("/tmp/app.v9db")

    if is_clean {
        println("✅ Database is clean")
    } else {
        ;; 복구 시작
        println("⚠️ Database requires recovery")
        var recovery = recover_database("/tmp/app.v9db")
        println("✅ Recovery completed")
        println("   Tables: " + str(recovery.tables_recovered))
        println("   WAL entries: " + str(recovery.wal_entries_to_replay))
    }

    println("")
}

fn test_8_auto_checkpoint() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 8: 자동 체크포인트                ║")
    println("╚═══════════════════════════════════════════╝")

    var table = table_new("logs", [])
    var i: i32 = 0
    while i < 10 {
        table = table_insert(table, ["L" + str(i), "Log entry " + str(i)])
        i = i + 1
    }

    var db = database_new("logging")
    db = database_add_table(db, table)

    ;; 스케줄러 생성
    var scheduler = checkpoint_scheduler_new(5000)  ;; 5초

    ;; 첫 번째 체크포인트
    var wal = wal_new()
    scheduler = perform_checkpoint(scheduler, db, wal)

    ;; 두 번째 체크포인트
    scheduler = perform_checkpoint(scheduler, db, wal)

    println("✅ Auto-checkpoint completed (" + str(scheduler.checkpoint_count) + " checkpoints)")
    println("")
}

fn test_9_crash_recovery() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 9: 크래시 복구 시뮬레이션         ║")
    println("╚═══════════════════════════════════════════╝")

    println("[CRASH] Simulating database crash...")
    println("[CRASH] Program crashed during transaction")
    println("")

    println("[RECOVERY] Starting crash recovery...")

    ;; 마지막 체크포인트 로드
    var checkpoint_db = restore_from_checkpoint("/tmp/checkpoint.snap")
    println("✅ Loaded last checkpoint")

    ;; WAL 재생
    var wal = wal_new()
    wal.entry_count = 3
    checkpoint_db = replay_wal_entries(checkpoint_db, wal)
    println("✅ Replayed WAL entries")

    ;; 무결성 검사
    var integrity = check_database_integrity(checkpoint_db)
    println("✅ Integrity verified")

    println("")
}

fn test_10_complete_workflow() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 10: 완전한 워크플로우             ║")
    println("╚═══════════════════════════════════════════╝")

    println("Step 1: 데이터베이스 생성")
    var table = table_new("customers", [])
    table = table_insert(table, ["C1", "Alice"])
    table = table_insert(table, ["C2", "Bob"])

    var db = database_new("crm")
    db = database_add_table(db, table)
    println("  ✓ Created")

    println("Step 2: 데이터 수정 (WAL 로그)")
    var wal = wal_new()
    wal = wal_append_insert(wal, "customers", 3, ["C3", "Charlie"])
    wal = wal_append_update(wal, "customers", 1, ["C1", "Alice"], ["C1", "Alice Smith"])
    println("  ✓ WAL logged")

    println("Step 3: 체크포인트 생성")
    var scheduler = checkpoint_scheduler_new(10000)
    var checkpoint = create_checkpoint(db, "/tmp/crm.checkpoint")
    println("  ✓ Checkpoint created")

    println("Step 4: 파일에 저장")
    var saved = database_save(db, "/tmp/crm.v9db")
    println("  ✓ Saved to file")

    println("Step 5: 무결성 검사")
    var integrity = check_database_integrity(db)
    println("  ✓ Integrity verified")

    println("Step 6: 백업 생성")
    var backup = create_backup(db, "/tmp/crm.backup")
    println("  ✓ Backup created")

    println("Step 7: 파일에서 로드")
    var loaded = database_load("/tmp/crm.v9db")
    println("  ✓ Loaded from file")

    println("")
}

