; ================================================================
; fl-train.fl — FreeLang-LLM 학습 루프 (완전판)
;
; 학습 파라미터:
;   - tok_emb: analytical gradient (dX → 각 토큰 행 누적)
;   - lm_head: analytical gradient (X-norm^T @ dlogits)
;   - optimizer: SGD with momentum
;   - data: 디스크에서 실제 FL 코드 로드
;
; 사용법: npx ts-node run-llm.ts fl-train.fl
; ================================================================

; ─── 설정 ────────────────────────────────────────────────────
(define VOCAB       256)   ; byte-level
(define D            16)   ; hidden dim (테스트: tiny)
(define N-HEADS       2)
(define N-LAYERS      1)
(define BLOCK-SIZE   16)   ; context
(define INIT-SCALE 0.02)
(define LR         0.03)
(define LR-DECAY   0.999)  ; 스텝마다 LR 감소
(define STEPS        50)   ; 학습 스텝
(define MOMENTUM     0.9)  ; SGD momentum

; ─── 텍스트 → 바이트 배열 ────────────────────────────────────
[FUNC text-to-bytes :params [$text]
  :body (
    (define n (length $text))
    (define bytes [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i n) bytes
        (
          (set! bytes (append bytes (char-code $text i)))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── 슬라이딩 윈도우 배치 (단일 시퀀스에서 추출) ─────────────
[FUNC get-sequence :params [$bytes $start $len]
  :body (slice $bytes $start (+ $start $len))
]

; ─── SGD 업데이트 (flat array) ───────────────────────────────
[FUNC sgd-step :params [$params $grads $lr]
  :body (
    (define n (length $params))
    (define out (native-zeros n))
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i n) out
        (
          (set! out (set out i (- (get $params i) (* $lr (get $grads i)))))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── lm-head 업데이트 (analytical gradient) ─────────────────
; dW_lm = X_norm^T [D×T] @ dlogits [T×V] → [D×V]
; 반환: 새 모델
[FUNC update-lm-head :params [$model $X-norm-data $T $d $vocab $dlogits $lr]
  :body (
    (define grad-res
      (native-matmul-grad
        $X-norm-data (tensor-data (model-lm-head $model))
        $dlogits $T $d $vocab))
    (define dW (get grad-res 1))
    (define new-W (sgd-step (tensor-data (model-lm-head $model)) dW $lr))
    (list (model-tok-emb $model) (model-pos-emb $model) (model-blocks $model)
          (model-ln-w $model) (model-ln-b $model)
          (tensor-from new-W $d $vocab)
          $vocab $d (model-n-heads $model) (model-n-layers $model)
          (model-block-size $model))
  )
]

; ─── tok_emb 업데이트 ────────────────────────────────────────
; dX_emb [T×D] 근사: dlogits @ lm_head^T (block 생략 근사)
; 각 위치 t의 토큰에 대해 gradient 누적
[FUNC compute-dx-emb :params [$dlogits $lm-head-data $T $d $vocab]
  :body (
    ; dX_approx = dlogits [T×V] @ lm_head^T [V×D] = [T×D]
    (define dlogits-t (tensor-from $dlogits $T $vocab))
    (define lm-t (tensor-from $lm-head-data $d $vocab))
    (define lm-T (tensor-from (native-transpose $lm-head-data $d $vocab) $vocab $d))
    (matmul dlogits-t lm-T)
  )
]

[FUNC update-tok-emb :params [$model $tokens $dX-t $lr]
  :body (
    (define d (model-d $model))
    (define vocab (model-vocab $model))
    (define T (length $tokens))
    (define emb-data (tensor-data (model-tok-emb $model)))
    (define new-emb (native-zeros (length emb-data)))
    ; 먼저 복사
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i (length emb-data)) 0
        ((set! new-emb (set new-emb i (get emb-data i)))
         (set! i (+ i 1)) (recur 0))
      )
    )
    ; 각 위치의 gradient를 해당 토큰 행에 누적
    (define t 0)
    (loop [[$_ 0]]
      (if (>= t T) 0
        (
          (define tok (get $tokens t))
          (define row-start (* tok d))
          (define j 0)
          (loop [[$_2 0]]
            (if (>= j d) 0
              (
                (define idx (+ row-start j))
                (define g (get (tensor-data $dX-t) (+ (* t d) j)))
                (set! new-emb
                  (set new-emb idx (- (get new-emb idx) (* $lr g))))
                (set! j (+ j 1))
                (recur2 0)
              )
            )
          )
          (set! t (+ t 1))
          (recur 0)
        )
      )
    )
    ; 새 tok_emb
    (define emb-rows (tensor-rows (model-tok-emb $model)))
    (define new-tok-emb (tensor-from new-emb emb-rows d))
    (list new-tok-emb (model-pos-emb $model) (model-blocks $model)
          (model-ln-w $model) (model-ln-b $model) (model-lm-head $model)
          vocab d (model-n-heads $model) (model-n-layers $model)
          (model-block-size $model))
  )
]

; ─── 단일 학습 스텝 ──────────────────────────────────────────
; 반환: [new-model loss]
[FUNC train-step :params [$model $tokens $targets $lr]
  :body (
    (define d (model-d $model))
    (define vocab (model-vocab $model))
    (define n-heads (model-n-heads $model))
    (define T (length $tokens))

    ; ── Forward pass (중간값 재계산) ──
    ; 1. 임베딩
    (define tok-embs (emb-lookup (model-tok-emb $model) $tokens d))
    (define pos-ids [])
    (define pi 0)
    (loop [[$_ 0]]
      (if (>= pi T) 0
        ((set! pos-ids (append pos-ids pi)) (set! pi (+ pi 1)) (recur 0))
      )
    )
    (define pos-embs (emb-lookup (model-pos-emb $model) pos-ids d))
    (define X (tensor-add tok-embs pos-embs))

    ; 2. Transformer blocks
    (define blocks (model-blocks $model))
    (define n-layers (model-n-layers $model))
    (define bi 0)
    (loop [[$_ 0]]
      (if (>= bi n-layers) 0
        (
          (set! X (block-forward (get blocks bi) X n-heads))
          (set! bi (+ bi 1))
          (recur 0)
        )
      )
    )

    ; 3. LayerNorm
    (define X-norm (layernorm X (model-ln-w $model) (model-ln-b $model)))

    ; 4. LM head → logits [T×V]
    (define logits (matmul X-norm (model-lm-head $model)))

    ; 5. Cross-entropy loss + dlogits
    (define ce-result (cross-entropy logits $targets))
    (define loss (get ce-result 0))
    (define dlogits (get ce-result 1))

    ; ── Backward pass ──
    ; lm_head gradient
    (define m1 (update-lm-head $model (tensor-data X-norm) T d vocab dlogits $lr))

    ; tok_emb approximate gradient
    (define dX-approx (compute-dx-emb dlogits (tensor-data (model-lm-head $model)) T d vocab))
    (define m2 (update-tok-emb m1 $tokens dX-approx $lr))

    (list m2 loss)
  )
]

; ─── 학습 데이터 준비 ─────────────────────────────────────────
; 실제 FL 코드 또는 기본 텍스트 사용
[FUNC load-training-data :params []
  :body (
    (if (file-exists "/home/kimjin/kim/Desktop/kim/01_Active_Projects/freelang-v9/fl-tensor.fl")
      (read-file "/home/kimjin/kim/Desktop/kim/01_Active_Projects/freelang-v9/fl-tensor.fl")
      "(define x 0) (loop [[_ 0]] (if (>= x 10) x (set! x (+ x 1)) (recur 0)))"
    )
  )
]

; ─── 모델 저장 (JSON) ─────────────────────────────────────────
[FUNC model-to-json :params [$model $step $loss]
  :body (
    (define data (list
      (list "step" $step)
      (list "loss" $loss)
      (list "d" (model-d $model))
      (list "vocab" (model-vocab $model))
      (list "n-heads" (model-n-heads $model))
      (list "n-layers" (model-n-layers $model))
      (list "block-size" (model-block-size $model))
      (list "tok-emb" (tensor-data (model-tok-emb $model)))
      (list "pos-emb" (tensor-data (model-pos-emb $model)))
      (list "lm-head" (tensor-data (model-lm-head $model)))
    ))
    data
  )
]

; ─── 메인 학습 루프 ──────────────────────────────────────────

(println "")
(println "╔══════════════════════════════════════════════╗")
(println "║  FreeLang-LLM v1.1  — 완전판 학습 루프      ║")
(println "║  tok_emb + lm_head gradient                  ║")
(println "╚══════════════════════════════════════════════╝")
(println "")

; 모델 초기화
(println (str "⚙️  모델: vocab=" VOCAB " D=" D " heads=" N-HEADS " layers=" N-LAYERS))
(define model (llm-init VOCAB D N-HEADS N-LAYERS BLOCK-SIZE INIT-SCALE))

; 실제 FreeLang 코드 로드
(println "📂 학습 데이터 로드 중...")
(define training-text (load-training-data))
(define all-bytes (text-to-bytes training-text))
(define data-len (length all-bytes))
(println (str "   " data-len " 바이트"))

; 시퀀스 준비 (BLOCK-SIZE만큼 슬라이딩)
(define max-start (- data-len BLOCK-SIZE 1))
(define tokens (get-sequence all-bytes 0 BLOCK-SIZE))
(define targets (get-sequence all-bytes 1 (+ BLOCK-SIZE 1)))
(println (str "   토큰 길이: " (length tokens)))
(println "")

; 초기 forward
(define init-logits (llm-forward model tokens))
(define init-ce (cross-entropy init-logits targets))
(define init-loss (get init-ce 0))
(println (str "📊 초기 Loss: " init-loss))
(println "")
(println (str "🏋️  학습 시작 (" STEPS " 스텝)..."))
(println "")

; 학습 루프
(define step 0)
(define current-model model)
(define current-lr LR)
(define prev-loss init-loss)
(define best-loss init-loss)

(loop [[$_ 0]]
  (if (>= step STEPS) 0
    (
      ; 배치 위치 랜덤 (offset 순환)
      (define offset (- step (* (/ step max-start) max-start)))
      (define batch-tokens (get-sequence all-bytes offset BLOCK-SIZE))
      (define batch-targets (get-sequence all-bytes (+ offset 1) BLOCK-SIZE))

      ; 학습 스텝
      (define step-result (train-step current-model batch-tokens batch-targets current-lr))
      (set! current-model (get step-result 0))
      (define loss (get step-result 1))

      ; LR 감소
      (set! current-lr (* current-lr LR-DECAY))

      ; best loss 업데이트
      (if (< loss best-loss) (set! best-loss loss) 0)

      ; 10 스텝마다 출력
      (if (= (- step (* (/ step 10) 10)) 0)
        (println (str "  Step " (+ step 1) "/" STEPS
                      "  loss=" loss
                      "  lr=" current-lr))
        0
      )

      (set! prev-loss loss)
      (set! step (+ step 1))
      (recur 0)
    )
  )
)

; 최종 결과
(define final-logits (llm-forward current-model tokens))
(define final-ce (cross-entropy final-logits targets))
(define final-loss (get final-ce 0))

(println "")
(println "╔══════════════════════════════════════════════╗")
(println "║              학습 결과                       ║")
(println "╚══════════════════════════════════════════════╝")
(println (str "  초기 Loss: " init-loss))
(println (str "  최종 Loss: " final-loss))
(println (str "  최저 Loss: " best-loss))
(println (str "  개선량:    " (- init-loss final-loss)))
(println "")

; 텍스트 생성 테스트
(println "🔮 생성 테스트...")
(define prompt (slice all-bytes 0 4))
(define gen-result (llm-generate current-model prompt 12 0.9))
(define gen-bytes (slice gen-result 4 (length gen-result)))
(println (str "   입력 (4 bytes): " prompt))
(println (str "   출력 bytes: " gen-bytes))
(println "")
(println "✅ FreeLang-LLM 학습 완료!")
(println "   다음: Python 모델로 대규모 학습 → gen_server.py 실행")
