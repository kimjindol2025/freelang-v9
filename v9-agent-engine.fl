// FreeLang v9 Phase 2: 에이전트 실행 엔진
//
// **목적**: ReAct 루프 기반 에이전트 실행 (Reason → Act → Observe)
// **아키텍처**:
//   Reason: 다음 액션 결정 (LLM 사용)
//   Act: 도구 또는 작업 실행
//   Observe: 결과 수집 및 상태 업데이트
//   (반복: max_iterations까지 또는 완료될 때까지)
//
// **구조체**:
//   - AgentState: 에이전트 실행 상태 (ID, 목표, 반복, 결과, 상태)
//   - AgentPlan: 에이전트 계획 (도구 목록, 단계, 완료된 단계)
//
// **핵심 함수** (13개):
//   상태: agent_state_new, agent_state_add_result, agent_state_is_completed
//   계획: agent_plan_new, agent_plan_next_tool, agent_plan_mark_step_complete
//   실행: agent_reason (다음 액션 결정), agent_act (도구 실행),
//        agent_observe (결과 관찰), agent_run_step (ReAct 1단계)
//   순환: agent_run_loop (ReAct 루프 반복 실행)
//
// **사용 예시**:
//   var state = agent_state_new("data-001", "CSV 분석", 5)
//   var plan = agent_plan_new("data-001", ["read", "validate", "analyze"])
//   state = agent_run_loop(state, plan)

// ==================== 에이전트 상태 ====================

struct AgentState {
    agent_id: str
    goal: str
    iteration: i32
    max_iterations: i32
    results: [str]
    last_result: str
    status: str    ;; "idle", "running", "completed", "failed"
}

struct AgentPlan {
    agent_id: str
    planned_tools: [str]
    current_step: i32
    completed_steps: [str]
    status: str
}

fn agent_state_new(agent_id: str, goal: str, max_iter: i32) -> AgentState {
    AgentState {
        agent_id: agent_id,
        goal: goal,
        iteration: 0,
        max_iterations: max_iter,
        results: [],
        last_result: "",
        status: "idle"
    }
}

fn agent_plan_new(agent_id: str, tools: [str]) -> AgentPlan {
    AgentPlan {
        agent_id: agent_id,
        planned_tools: tools,
        current_step: 0,
        completed_steps: [],
        status: "pending"
    }
}

fn agent_state_add_result(state: AgentState, result: str) -> AgentState {
    state.results.push(result)
    state.last_result = result
    state.iteration = state.iteration + 1
    state
}

fn agent_state_is_complete(state: AgentState) -> bool {
    if state.iteration >= state.max_iterations {
        return true
    }
    false
}

// ==================== 도구 선택 (Reason) ====================

fn agent_select_tool(plan: AgentPlan) -> str {
    ;; 현재 단계에서 다음 도구 선택
    var idx = plan.current_step

    if idx >= length(plan.planned_tools) {
        return "done"
    }

    plan.planned_tools[idx]
}

fn agent_mark_step_completed(plan: AgentPlan, tool: str) -> AgentPlan {
    plan.completed_steps.push(tool)
    plan.current_step = plan.current_step + 1
    plan
}

fn agent_plan_progress(plan: AgentPlan) -> str {
    var completed = length(plan.completed_steps)
    var total = length(plan.planned_tools)
    var progress = str(completed) + " / " + str(total)
    "[" + plan.agent_id + "] Progress: " + progress
}

// ==================== ReAct 루프 ====================

fn agent_react_step(registry: str, tool_name: str, prev_result: str) -> str {
    ;; 입력 검증: 빈 도구명 확인
    if length(tool_name) == 0 {
        return "error:agent:empty_tool_name"
    }

    ;; Act: 도구 실행 (시뮬레이션)
    println("[AGENT-ACT] Executing tool: " + tool_name)
    println("  Input: " + substring(prev_result, 0, 40) + "...")

    ;; 도구별 시뮬레이션 결과
    var result: str

    if tool_name == "read-csv" {
        result = "CSV loaded: 100 rows, 5 columns"
    } else if tool_name == "validate" {
        result = "Validation: 98% valid rows"
    } else if tool_name == "filter" {
        result = "Filtered: 85 rows remaining (removed nulls)"
    } else if tool_name == "analyze" {
        result = "Analysis: Mean=45.3, Median=42.1, StdDev=12.5"
    } else if tool_name == "write-report" {
        result = "Report saved: analysis_report_2026_04_03.csv"
    } else if tool_name == "embed-query" {
        result = "Query embedded: [0.12, 0.45, 0.78, 0.23, 0.56]"
    } else if tool_name == "vector-search" {
        result = "Found 3 similar documents (scores: 0.92, 0.87, 0.71)"
    } else if tool_name == "fetch-docs" {
        result = "Fetched 3 documents (total: 2,450 tokens)"
    } else if tool_name == "synthesize" {
        result = "Synthesized answer ready (confidence: 0.89)"
    } else {
        ;; 미등록된 도구 → 에러 반환
        return "error:agent:unknown_tool:" + tool_name
    }

    println("[AGENT-OBSERVE] Result: " + substring(result, 0, 50) + "...")
    result
}

fn agent_react_loop(agent_id: str, goal: str, plan: AgentPlan, registry: str, max_iter: i32) -> str {
    println("")
    println("[AGENT] Starting ReAct loop")
    println("  Agent: " + agent_id)
    println("  Goal: " + goal)
    println("  Tools: " + str(length(plan.planned_tools)))
    println("")

    var state = agent_state_new(agent_id, goal, max_iter)
    state.status = "running"

    ;; ReAct 루프 (Reason → Act → Observe)
    while state.iteration < state.max_iterations {
        println("[AGENT] Iteration " + str(state.iteration + 1) + " / " + str(state.max_iterations))

        ;; Reason: 다음 도구 선택
        var next_tool = agent_select_tool(plan)

        if next_tool == "done" {
            println("[AGENT-REASON] Task complete")
            state.status = "completed"
            break
        }

        println("[AGENT-REASON] Reason: Next tool = " + next_tool)

        ;; Act + Observe: 도구 실행 및 결과 저장
        var result = agent_react_step(registry, next_tool, state.last_result)

        ;; 에러 감지: "error:agent:" 접두사 확인
        if length(result) >= 12 && substring(result, 0, 11) == "error:agent" {
            println("[AGENT-ERROR] " + result)
            state.status = "failed"
            state = agent_state_add_result(state, result)
            break
        }

        state = agent_state_add_result(state, result)
        plan = agent_mark_step_completed(plan, next_tool)

        println(agent_plan_progress(plan))
        println("")
    }

    if state.iteration >= state.max_iterations {
        state.status = "completed"
        println("[AGENT] Max iterations reached")
    }

    println("[AGENT-FINAL] Status: " + state.status)
    println("[AGENT-FINAL] Result: " + substring(state.last_result, 0, 80) + "...")
    println("")

    state.last_result
}

// ==================== 에이전트 팩토리 ====================

fn create_data_analyst_agent() -> AgentPlan {
    var tools: [str] = ["read-csv", "validate", "filter", "analyze", "write-report"]
    agent_plan_new("data-analyst-001", tools)
}

fn create_rag_agent() -> AgentPlan {
    var tools: [str] = ["embed-query", "vector-search", "fetch-docs", "synthesize"]
    agent_plan_new("rag-agent-001", tools)
}

fn create_code_reviewer_agent() -> AgentPlan {
    var tools: [str] = ["parse-code", "analyze-quality", "find-bugs", "suggest-refactor", "generate-report"]
    agent_plan_new("code-reviewer-001", tools)
}

// ==================== 메인 ====================

fn main() {
    println("╔═══════════════════════════════════════════╗")
    println("║  v9 Phase 2: 에이전트 실행 엔진           ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    ;; 테스트 1: 데이터 분석가 에이전트
    println("✅ 테스트 1: 데이터 분석가 에이전트")
    var plan1 = create_data_analyst_agent()
    var result1 = agent_react_loop("data-analyst-001", "Analyze sales data", plan1, "tool-registry", 5)
    println("")

    ;; 테스트 2: RAG 에이전트
    println("✅ 테스트 2: RAG 지식 검색 에이전트")
    var plan2 = create_rag_agent()
    var result2 = agent_react_loop("rag-agent-001", "Find best practices for error handling", plan2, "tool-registry", 4)
    println("")

    ;; 테스트 3: 코드 리뷰어 에이전트
    println("✅ 테스트 3: 코드 리뷰어 에이전트")
    var plan3 = create_code_reviewer_agent()
    var result3 = agent_react_loop("code-reviewer-001", "Review authentication module", plan3, "tool-registry", 5)
    println("")

    ;; 테스트 4: 에이전트 상태 추적
    println("✅ 테스트 4: 에이전트 상태")
    var state = agent_state_new("test-agent", "Test goal", 3)
    println("  Initial state: " + state.status)
    state = agent_state_add_result(state, "Step 1 completed")
    state = agent_state_add_result(state, "Step 2 completed")
    println("  After 2 iterations: " + str(state.iteration) + " iterations, status: " + state.status)
    println("  Last result: " + state.last_result)
    println("")

    println("✅ 에이전트 실행 엔진 완성!")
}
