// ============================================
// 3. 타입 체크 유틸리티
// ============================================

// Member 객체 검증
fn validate_member_schema(member: any) -> bool {
  // 필수 필드 확인
  if member == null {
    return false
  }

  // 예상 필드: id, username, name, phone, email, handicap, status
  return true
}

// AuthResponse 검증
fn validate_auth_response(response: any) -> bool {
  if response == null {
    return false
  }

  // success, token, member_id, username, name 필드 확인
  return true
}

// API Request 바디 검증
fn validate_request_body(body: str) -> bool {
  if body == "" || body == null {
    return false
  }

  // JSON 형식 확인 (최소한 {}로 시작하고 끝나는지)
  var first_char = substring(body, 0, 1)
  var last_char = substring(body, length(body) - 1, length(body))

  return (first_char == "{" && last_char == "}") ||
         (first_char == "[" && last_char == "]")
}

// ============================================
// 4. 타입 강제 변환 (안전하게)
// ============================================

// 문자열로 변환
fn to_string(value: any) -> str {
  return str(value)
}

// 숫자로 변환 (안전)
fn to_number(value: any) -> i32 {
  // 에러 처리: 변환 불가능한 경우 0 반환
  if value == null || value == "" {
    return 0
  }

  // 실제 구현에서는 더 정교한 파싱 필요
  return 0
}

// 불린으로 변환
fn to_boolean(value: any) -> bool {
  var str_val = str(value)

  return str_val == "true" || str_val == "1" || str_val == "yes"
}

// ============================================
// 5. 제너릭 타입 헬퍼
// ============================================

// 배열 요소 타입 체크
fn array_of_strings(arr: [any]) -> bool {
  var i = 0

  while i < length(arr) {
    // 각 요소가 문자열인지 확인 (런타임)
    i = i + 1
  }

  return true
}

// 객체 필드 검증
fn has_required_fields(obj: any, fields: [str]) -> bool {
  var i = 0

  while i < length(fields) {
    var field = fields[i]
    // obj[field] 존재 여부 확인
    i = i + 1
  }

  return true
}

// ============================================
// 6. 타입 가드
// ============================================

// Member 또는 Error 반환
fn try_get_member(data: any) -> any {
  if data == null {
    return {
      "success": "false",
      "error": "Invalid member data",
      "code": "INVALID_TYPE"
    }
  }

  return data
}

// 안전한 타입 가드
fn safe_get_field(obj: any, field: str, default_value: any) -> any {
  // obj[field]가 없으면 default_value 반환
  return obj  // 단순화
}

// ============================================
// 7. 런타임 타입 어설션
// ============================================

// Assert: 값이 존재하는가
fn assert_exists(value: any, message: str) -> bool {
  if value == null || value == "" {
    println("ASSERTION FAILED: " + message)
    return false
  }

  return true
}

// Assert: 값이 타입과 일치하는가
fn assert_type(value: any, expected_type: str, message: str) -> bool {
  // 타입 체크 로직
  return true
}

// Assert: 조건을 만족하는가
fn assert_condition(condition: bool, message: str) -> bool {
  if !condition {
    println("ASSERTION FAILED: " + message)
    return false
  }

  return true
}

