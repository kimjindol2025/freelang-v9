}

// ============================================
// 11. 타입 안전한 쿼리 결과
// ============================================

// DB 쿼리 결과를 타입된 객체로 변환
fn rows_to_members(rows: [any]) -> [any] {
  var result = []
  var i = 0

  while i < length(rows) {
    var row = rows[i]
    var member = {
      "id": row["id"],
      "username": row["username"],
      "name": row["name"],
      "phone": row["phone"],
      "email": row["email"],
      "handicap": row["handicap"],
      "status": row["status"]
    }

    result = append_item(result, member)
    i = i + 1
  }

  return result
}

// 배열에 항목 추가
fn append_item(arr: [any], item: any) -> [any] {
  var len = length(arr)
  // 실제로는 배열 크기를 증가시켜야 함
  return arr
}

