; ================================================================
; FreeLang v9 — GPT Transformer Phase 1: Forward Pass
;
; 소형 모델:  vocab=32  d=8  heads=2  dh=4  ffn=16  layers=2
; 목표: FreeLang v9에서 Transformer forward pass 동작 검증
; ================================================================

; ─── 설정 ──────────────────────────────────────────────────────

(define VOCAB  32)
(define D       8)
(define HEADS   2)
(define DH      4)   ; D / HEADS
(define FFN    16)
(define LAYERS  2)
(define SEQ     6)

; ─── 벡터 유틸 ─────────────────────────────────────────────────

[FUNC zeros :params [$n]
  :body (
    (define v [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i $n) v
        ((set! v (append v 0.0)) (set! i (+ i 1)) (recur 0))
      )
    )
  )
]

[FUNC rand-vec :params [$n $scale]
  :body (
    (define v [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i $n) v
        (
          (define r (* (- (* (random) 2.0) 1.0) $scale))
          (set! v (append v r))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

[FUNC ones :params [$n]
  :body (
    (define v [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i $n) v
        ((set! v (append v 1.0)) (set! i (+ i 1)) (recur 0))
      )
    )
  )
]

; v1 + v2 (같은 크기)
[FUNC vadd :params [$a $b]
  :body (
    (define n (length $a))
    (define v [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i n) v
        (
          (set! v (append v (+ (get $a i) (get $b i))))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

; 내적
[FUNC vdot :params [$a $b]
  :body (
    (define n (length $a))
    (define s 0.0)
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i n) s
        (
          (set! s (+ s (* (get $a i) (get $b i))))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

; 행렬(rows×cols flat) × 벡터(cols) → 벡터(rows)
[FUNC mv :params [$W $rows $cols $x]
  :body (
    (define y [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i $rows) y
        (
          (define s 0.0)
          (define j 0)
          (loop [[$_ 0]]
            (if (>= j $cols) 0
              (
                (set! s (+ s (* (get $W (+ (* i $cols) j)) (get $x j))))
                (set! j (+ j 1))
                (recur 0)
              )
            )
          )
          (set! y (append y s))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── Softmax ───────────────────────────────────────────────────

[FUNC softmax :params [$x]
  :body (
    (define n (length $x))
    (define mx (get $x 0))
    (define i 1)
    (loop [[$_ 0]]
      (if (>= i n) 0
        (
          (if (> (get $x i) mx) (set! mx (get $x i)) 0)
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
    (define exps [])
    (define sum 0.0)
    (set! i 0)
    (loop [[$_ 0]]
      (if (>= i n) 0
        (
          (define e (exp (- (get $x i) mx)))
          (set! exps (append exps e))
          (set! sum (+ sum e))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
    (define out [])
    (set! i 0)
    (loop [[$_ 0]]
      (if (>= i n) out
        (
          (set! out (append out (/ (get exps i) sum)))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── Layer Norm ────────────────────────────────────────────────

[FUNC layer-norm :params [$x $scale $bias]
  :body (
    (define n (length $x))
    (define mu 0.0)
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i n) 0
        ((set! mu (+ mu (get $x i))) (set! i (+ i 1)) (recur 0))
      )
    )
    (set! mu (/ mu n))
    (define vr 0.0)
    (set! i 0)
    (loop [[$_ 0]]
      (if (>= i n) 0
        (
          (define d (- (get $x i) mu))
          (set! vr (+ vr (* d d)))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
    (define inv-std (/ 1.0 (sqrt (+ (/ vr n) 0.00001))))
    (define out [])
    (set! i 0)
    (loop [[$_ 0]]
      (if (>= i n) out
        (
          (define xn (* (- (get $x i) mu) inv-std))
          (set! out (append out (+ (* xn (get $scale i)) (get $bias i))))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── GELU ──────────────────────────────────────────────────────

[FUNC gelu :params [$x]
  :body (* $x (/ 1.0 (+ 1.0 (exp (* -1.702 $x)))))
]

; ─── FFN (per position) ────────────────────────────────────────

[FUNC ffn :params [$x $W1 $b1 $W2 $b2 $d $ffn-dim]
  :body (
    ; h = GELU(W1·x + b1)
    (define h [])
    (define j 0)
    (loop [[$_ 0]]
      (if (>= j $ffn-dim) 0
        (
          (define s (get $b1 j))
          (define k 0)
          (loop [[$_ 0]]
            (if (>= k $d) 0
              (
                (set! s (+ s (* (get $W1 (+ (* k $ffn-dim) j)) (get $x k))))
                (set! k (+ k 1))
                (recur 0)
              )
            )
          )
          (set! h (append h (gelu s)))
          (set! j (+ j 1))
          (recur 0)
        )
      )
    )
    ; out = W2·h + b2
    (define out [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i $d) out
        (
          (define s (get $b2 i))
          (set! j 0)
          (loop [[$_ 0]]
            (if (>= j $ffn-dim) 0
              (
                (set! s (+ s (* (get $W2 (+ (* j $d) i)) (get $h j))))
                (set! j (+ j 1))
                (recur 0)
              )
            )
          )
          (set! out (append out s))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── 벡터 원소 교체 ───────────────────────────────────────────
; (vec-set v i val) → v[i]=val 인 새 벡터

[FUNC vec-set :params [$v $idx $val]
  :body (
    (define n (length $v))
    (define result [])
    (define j 0)
    (loop [[$_ 0]]
      (if (>= j n) result
        (
          (if (= j $idx)
            (set! result (append result $val))
            (set! result (append result (get $v j)))
          )
          (set! j (+ j 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── Causal Self-Attention (단일 헤드, 위치 i) ─────────────────
; Q,K,V: seq×dh flat 배열
; 위치 i에서의 attention output (dh 크기 벡터)

[FUNC attn-pos :params [$Q $K $V $i $seq $dh]
  :body (
    (define scale (/ 1.0 (sqrt $dh)))
    ; scores[j] = Q[i]·K[j]/sqrt(dh)  (j <= i: causal)
    (define scores [])
    (define j 0)
    (loop [[$_ 0]]
      (if (>= j $seq) 0
        (
          (define score
            (if (<= j $i)
              (* (vdot
                    (slice $Q (* $i $dh) (+ (* $i $dh) $dh))
                    (slice $K (* j $dh) (+ (* j $dh) $dh))
                 )
                 scale)
              -999999999.0)
          )
          (set! scores (append scores score))
          (set! j (+ j 1))
          (recur 0)
        )
      )
    )
    (define attn (softmax scores))
    ; weighted sum of V[j] for j in [0, seq)
    (define out (zeros $dh))
    (set! j 0)
    (loop [[$_ 0]]
      (if (>= j $seq) out
        (
          (define w (get attn j))
          (define k 0)
          (loop [[$_ 0]]
            (if (>= k $dh) 0
              (
                (define cur-val (get out k))
                (define new-val (+ cur-val (* w (get $V (+ (* j $dh) k)))))
                (set! out (vec-set out k new-val))
                (set! k (+ k 1))
                (recur 0)
              )
            )
          )
          (set! j (+ j 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── Multi-Head Attention (전체 시퀀스) ────────────────────────
; x: seq×d flat
; Wq,Wk,Wv,Wo: d×d
; 반환: seq×d flat

[FUNC mha :params [$x $Wq $Wk $Wv $Wo $seq $d $heads $dh]
  :body (
    ; 모든 위치의 Q,K,V 계산
    (define Q [])
    (define K [])
    (define V [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i $seq) 0
        (
          (define xi (slice $x (* i $d) (+ (* i $d) $d)))
          (set! Q (append Q (mv $Wq $d $d xi)))
          (set! K (append K (mv $Wk $d $d xi)))
          (set! V (append V (mv $Wv $d $d xi)))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
    ; 헤드별 attention + concat → Wo 투영
    (define mha-out [])
    (set! i 0)
    (loop [[$_ 0]]
      (if (>= i $seq) mha-out
        (
          ; 모든 헤드의 출력을 concat
          (define head-cat [])
          (define h 0)
          (loop [[$_ 0]]
            (if (>= h $heads) 0
              (
                ; 헤드 h의 Q,K,V (각 위치에서 hoff..hoff+dh 슬라이스)
                (define Qh [])
                (define Kh [])
                (define Vh [])
                (define ii 0)
                (loop [[$_ 0]]
                  (if (>= ii $seq) 0
                    (
                      (define hoff (* h $dh))
                      (set! Qh (append Qh (slice $Q (+ (* ii $d) hoff) (+ (* ii $d) hoff $dh))))
                      (set! Kh (append Kh (slice $K (+ (* ii $d) hoff) (+ (* ii $d) hoff $dh))))
                      (set! Vh (append Vh (slice $V (+ (* ii $d) hoff) (+ (* ii $d) hoff $dh))))
                      (set! ii (+ ii 1))
                      (recur 0)
                    )
                  )
                )
                ; 위치 i에서 헤드 h의 attention
                (define head-out (attn-pos Qh Kh Vh i $seq $dh))
                (set! head-cat (append head-cat head-out))
                (set! h (+ h 1))
                (recur 0)
              )
            )
          )
          ; Wo 투영
          (set! mha-out (append mha-out (mv $Wo $d $d head-cat)))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── Transformer Block ─────────────────────────────────────────
; x: seq×d flat
; 반환: seq×d flat (residual + MHA + LN + FFN + LN)

[FUNC transformer-block :params [$x $blk]
  :body (
    (define seq (get $blk :seq))
    (define d   (get $blk :d))
    (define heads (get $blk :heads))
    (define dh  (get $blk :dh))
    (define ffn-dim (get $blk :ffn))

    ; 1) 각 위치에 LN1 적용
    (define x-ln1 [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i seq) 0
        (
          (define xi (slice $x (* i d) (+ (* i d) d)))
          (set! x-ln1 (append x-ln1 (layer-norm xi (get $blk :ln1s) (get $blk :ln1b))))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )

    ; 2) MHA
    (define attn-out (mha x-ln1
                          (get $blk :Wq) (get $blk :Wk)
                          (get $blk :Wv) (get $blk :Wo)
                          seq d heads dh))

    ; 3) Residual: x + attn-out
    (define x2 (vadd $x attn-out))

    ; 4) 각 위치에 LN2 + FFN
    (define x-out [])
    (set! i 0)
    (loop [[$_ 0]]
      (if (>= i seq) x-out
        (
          (define x2i (slice x2 (* i d) (+ (* i d) d)))
          (define ln2i (layer-norm x2i (get $blk :ln2s) (get $blk :ln2b)))
          (define ffni (ffn ln2i (get $blk :W1) (get $blk :b1)
                               (get $blk :W2) (get $blk :b2) d ffn-dim))
          ; Residual: x2 + ffn
          (set! x-out (append x-out (vadd x2i ffni)))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── 가중치 초기화 ──────────────────────────────────────────────

[FUNC make-block :params [$d $dh $ffn-dim $heads $seq]
  :body (
    (define sa (/ 0.02 (sqrt (* $d $d))))
    (define sf (/ 0.02 (sqrt (* $d $ffn-dim))))
    {:Wq  (rand-vec (* $d $d) sa)
     :Wk  (rand-vec (* $d $d) sa)
     :Wv  (rand-vec (* $d $d) sa)
     :Wo  (rand-vec (* $d $d) sa)
     :ln1s (ones $d)  :ln1b (zeros $d)
     :W1  (rand-vec (* $d $ffn-dim) sf)
     :b1  (zeros $ffn-dim)
     :W2  (rand-vec (* $ffn-dim $d) sf)
     :b2  (zeros $d)
     :ln2s (ones $d)  :ln2b (zeros $d)
     :d $d  :dh $dh  :ffn $ffn-dim  :heads $heads  :seq $seq}
  )
]

; ─── Forward Pass ──────────────────────────────────────────────

[FUNC forward :params [$tokens $W-emb $blocks $W-proj $b-proj]
  :body (
    (define seq (length $tokens))
    (define d D)

    ; Embedding (+ 단순 위치 인코딩: pos * 0.01)
    (define x [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i seq) 0
        (
          (define tok (get $tokens i))
          (define emb (slice $W-emb (* tok d) (+ (* tok d) d)))
          ; 위치 인코딩: 짝수 인덱스 += sin(pos/10000^(j/d))
          ; 단순 버전: j번째 원소 += (pos/seq) * 0.1
          (define pe [])
          (define j 0)
          (loop [[$_ 0]]
            (if (>= j d) 0
              (
                (define pos-val (* (/ i (+ seq 1.0)) (if (= (floor (/ j 2)) (/ j 2)) 0.1 -0.1)))
                (set! pe (append pe pos-val))
                (set! j (+ j 1))
                (recur 0)
              )
            )
          )
          (set! x (append x (vadd emb pe)))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )

    ; Transformer Blocks
    (define cur x)
    (set! i 0)
    (loop [[$_ 0]]
      (if (>= i (length $blocks)) 0
        (
          (set! cur (transformer-block cur (get $blocks i)))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )

    ; LM Head: 마지막 위치 → logits (VOCAB 크기)
    (define last-x (slice cur (* (- seq 1) d) (* seq d)))
    (define logits (vadd (mv $W-proj VOCAB d last-x) $b-proj))
    logits
  )
]

; ─── 메인: 초기화 + Forward 테스트 ───────────────────────────

(define W-emb   (rand-vec (* VOCAB D) 0.02))
(define blocks  [(make-block D DH FFN HEADS SEQ)
                 (make-block D DH FFN HEADS SEQ)])
(define W-proj  (rand-vec (* D VOCAB) 0.02))
(define b-proj  (zeros VOCAB))

(define tokens [3 7 1 12 5 0])   ; 길이 6 시퀀스

(println "=== FreeLang v9 Transformer ===")
(println (str "vocab="   VOCAB))
(println (str "d_model=" D))
(println (str "heads="   HEADS))
(println (str "layers="  LAYERS))
(println (str "seq_len=" SEQ))
(println "")
(println "Forward pass 실행 중...")

(define logits (forward tokens W-emb blocks W-proj b-proj))
(define probs (softmax logits))

(println (str "logits 크기: " (length logits)))
(println (str "probs 크기:  " (length probs)))

; prob 합 확인
(define prob-sum 0.0)
(define i 0)
(loop [[$_ 0]]
  (if (>= i (length probs)) 0
    (
      (set! prob-sum (+ prob-sum (get probs i)))
      (set! i (+ i 1))
      (recur 0)
    )
  )
)
(println (str "probs 합계: " prob-sum))

; argmax (가장 높은 확률 토큰)
(define best-tok 0)
(define best-prob (get probs 0))
(set! i 1)
(loop [[$_ 0]]
  (if (>= i (length probs)) 0
    (
      (if (> (get probs i) best-prob)
        ((set! best-prob (get probs i)) (set! best-tok i))
        0
      )
      (set! i (+ i 1))
      (recur 0)
    )
  )
)
(println (str "다음 토큰 예측: " best-tok))
(println (str "확률: " best-prob))
(println "")
(println "=== PASS: Forward Pass 완료 ===")

; ================================================================
; Phase 2: 학습 루프 — Cross-entropy Loss + 수치미분 + SGD
;
; 전략: W-emb만 업데이트 (가장 단순)
; - 수치미분: (f(x+h) - f(x-h)) / (2h)
; - SGD: W[i] = W[i] - lr * grad[i]
; ================================================================

(println "")
(println "=== Phase 2: 학습 루프 시작 ===")

; cross-entropy loss (scalar)
[FUNC ce-loss :params [$toks $W-e $blks $Wp $bp $target]
  :body (
    (define lg (forward $toks $W-e $blks $Wp $bp))
    (define pr (softmax lg))
    (define p (get pr $target))
    (define safe-p (if (< p 0.000001) 0.000001 p))
    (* -1.0 (log safe-p))
  )
]

; W-emb[tok] 행에 대한 수치미분 (중앙차분)
; W-emb은 flat 1D: 행 tok의 j번째 원소 = W-emb[tok*D + j]
[FUNC grad-emb-row :params [$toks $W-e $blks $Wp $bp $target $tok $h]
  :body (
    (define grads [])
    (define j 0)
    (loop [[$_ 0]]
      (if (>= j D) grads
        (
          (define idx (+ (* $tok D) j))
          (define orig (get $W-e idx))
          ; f(x+h)
          (define We-p (vec-set $W-e idx (+ orig $h)))
          (define fp (ce-loss $toks We-p $blks $Wp $bp $target))
          ; f(x-h)
          (define We-m (vec-set $W-e idx (- orig $h)))
          (define fm (ce-loss $toks We-m $blks $Wp $bp $target))
          ; 중앙차분
          (define g (/ (- fp fm) (* 2.0 $h)))
          (set! grads (append grads g))
          (set! j (+ j 1))
          (recur 0)
        )
      )
    )
  )
]

; SGD: W-emb[tok] 행 업데이트
[FUNC sgd-update-row :params [$W-e $tok $grads $lr]
  :body (
    (define j 0)
    (loop [[$_ 0]]
      (if (>= j D) $W-e
        (
          (define idx (+ (* $tok D) j))
          (define g (get $grads j))
          (set! $W-e (vec-set $W-e idx (- (get $W-e idx) (* $lr g))))
          (set! j (+ j 1))
          (recur 0)
        )
      )
    )
  )
]

; 학습 하이퍼파라미터
(define TRAIN-LR  0.5)      ; 더 큰 LR
(define TRAIN-H   0.0001)   ; 수치미분 h
(define TRAIN-STEPS 10)
(define TARGET-TOK 5)       ; 다음 토큰 정답 (예: 토큰 5)

; W-emb 복사 (학습용)
(define W-emb-train W-emb)

; 초기 loss
(define loss0 (ce-loss tokens W-emb-train blocks W-proj b-proj TARGET-TOK))
(println (str "초기 loss: " loss0))
(println "")

; 학습 루프 — 시퀀스 내 모든 토큰 업데이트
(define step 0)
(loop [[$_ 0]]
  (if (>= step TRAIN-STEPS) 0
    (
      ; 현재 loss
      (define cur-loss (ce-loss tokens W-emb-train blocks W-proj b-proj TARGET-TOK))

      ; 시퀀스의 각 토큰에 대해 수치미분 + SGD
      (define ti 0)
      (loop [[$_ 0]]
        (if (>= ti (length tokens)) 0
          (
            (define tok (get tokens ti))
            (define grads (grad-emb-row tokens W-emb-train blocks W-proj b-proj TARGET-TOK tok TRAIN-H))
            (set! W-emb-train (sgd-update-row W-emb-train tok grads TRAIN-LR))
            (set! ti (+ ti 1))
            (recur 0)
          )
        )
      )

      (println (str "Step " (+ step 1) " | loss=" cur-loss))
      (set! step (+ step 1))
      (recur 0)
    )
  )
)

; 최종 loss
(define loss-final (ce-loss tokens W-emb-train blocks W-proj b-proj TARGET-TOK))
(println "")
(println (str "최종 loss: " loss-final))
(define improved (< loss-final loss0))
(println (str "loss 감소: " improved))
(println "=== Phase 2 완료 ===")

; ================================================================
; Phase 3: W-emb + W-proj 동시 역전파
;
; 소형 설정: MINI-VOCAB=8  MINI-D=4  MINI-HEADS=1  MINI-SEQ=3
; 학습 과제: tokens=[0,1,2] → target=3  ("ABCD" 예측)
; ================================================================

; ─── 소형 설정 ──────────────────────────────────────────────────
(define MINI-VOCAB  8)
(define MINI-D      4)
(define MINI-DH     4)   ; heads=1 이므로 dh=d
(define MINI-FFN    8)
(define MINI-HEADS  1)
(define MINI-SEQ    3)
(define MINI-TARGET 3)   ; 토큰 3 예측
(define MINI-TOKENS [0 1 2])

; ─── MINI forward (MINI-D, MINI-VOCAB 사용) ─────────────────────
[FUNC forward-mini :params [$tokens $W-emb $blocks $W-proj $b-proj]
  :body (
    (define seq (length $tokens))
    (define d MINI-D)

    ; Embedding + 위치 인코딩
    (define x [])
    (define i 0)
    (loop [[$_ 0]]
      (if (>= i seq) 0
        (
          (define tok (get $tokens i))
          (define emb (slice $W-emb (* tok d) (+ (* tok d) d)))
          (define pe [])
          (define j 0)
          (loop [[$_ 0]]
            (if (>= j d) 0
              (
                (define pos-val (* (/ i (+ seq 1.0)) (if (= (floor (/ j 2)) (/ j 2)) 0.1 -0.1)))
                (set! pe (append pe pos-val))
                (set! j (+ j 1))
                (recur 0)
              )
            )
          )
          (set! x (append x (vadd emb pe)))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )

    ; Transformer Blocks
    (define cur x)
    (set! i 0)
    (loop [[$_ 0]]
      (if (>= i (length $blocks)) 0
        (
          (set! cur (transformer-block cur (get $blocks i)))
          (set! i (+ i 1))
          (recur 0)
        )
      )
    )

    ; LM Head
    (define last-x (slice cur (* (- seq 1) d) (* seq d)))
    (define logits (vadd (mv $W-proj MINI-VOCAB d last-x) $b-proj))
    logits
  )
]

[FUNC ce-loss-mini :params [$toks $W-e $blks $Wp $bp $target]
  :body (
    (define lg (forward-mini $toks $W-e $blks $Wp $bp))
    (define pr (softmax lg))
    (define p (get pr $target))
    (define safe-p (if (< p 0.000001) 0.000001 p))
    (* -1.0 (log safe-p))
  )
]

; ─── W-emb 수치 기울기 (MINI-D 기준) ───────────────────────────
[FUNC grad-emb-row-mini :params [$toks $W-e $blks $Wp $bp $target $tok $h]
  :body (
    (define grads [])
    (define j 0)
    (loop [[$_ 0]]
      (if (>= j MINI-D) grads
        (
          (define idx (+ (* $tok MINI-D) j))
          (define orig (get $W-e idx))
          (define We-p (vec-set $W-e idx (+ orig $h)))
          (define fp (ce-loss-mini $toks We-p $blks $Wp $bp $target))
          (define We-m (vec-set $W-e idx (- orig $h)))
          (define fm (ce-loss-mini $toks We-m $blks $Wp $bp $target))
          (define g (/ (- fp fm) (* 2.0 $h)))
          (set! grads (append grads g))
          (set! j (+ j 1))
          (recur 0)
        )
      )
    )
  )
]

[FUNC sgd-update-row-mini :params [$W-e $tok $grads $lr]
  :body (
    (define j 0)
    (loop [[$_ 0]]
      (if (>= j MINI-D) $W-e
        (
          (define idx (+ (* $tok MINI-D) j))
          (define g (get $grads j))
          (set! $W-e (vec-set $W-e idx (- (get $W-e idx) (* $lr g))))
          (set! j (+ j 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── W-proj 수치 기울기 ─────────────────────────────────────────
; W-proj: MINI-VOCAB × MINI-D flat
; 행 r의 원소: W-proj[r*MINI-D + j], j=0..MINI-D-1
[FUNC grad-proj-row :params [$toks $W-e $blks $Wp $bp $target $row $h]
  :body (
    (define grads [])
    (define j 0)
    (loop [[$_ 0]]
      (if (>= j MINI-D) grads
        (
          (define idx (+ (* $row MINI-D) j))
          (define orig (get $Wp idx))
          (define Wp-p (vec-set $Wp idx (+ orig $h)))
          (define fp (ce-loss-mini $toks $W-e $blks Wp-p $bp $target))
          (define Wp-m (vec-set $Wp idx (- orig $h)))
          (define fm (ce-loss-mini $toks $W-e $blks Wp-m $bp $target))
          (define g (/ (- fp fm) (* 2.0 $h)))
          (set! grads (append grads g))
          (set! j (+ j 1))
          (recur 0)
        )
      )
    )
  )
]

[FUNC sgd-update-proj-row :params [$Wp $row $grads $lr]
  :body (
    (define j 0)
    (loop [[$_ 0]]
      (if (>= j MINI-D) $Wp
        (
          (define idx (+ (* $row MINI-D) j))
          (define g (get $grads j))
          (set! $Wp (vec-set $Wp idx (- (get $Wp idx) (* $lr g))))
          (set! j (+ j 1))
          (recur 0)
        )
      )
    )
  )
]

; ─── W-emb + W-proj 동시 업데이트 ──────────────────────────────
[FUNC train-step-full :params [$toks $W-e $blks $Wp $bp $target $lr $h]
  :body (
    ; W-emb 업데이트: 각 입력 토큰 행
    (define ti 0)
    (loop [[$_ 0]]
      (if (>= ti (length $toks)) 0
        (
          (define tok (get $toks ti))
          (define ge (grad-emb-row-mini $toks $W-e $blks $Wp $bp $target tok $h))
          (set! $W-e (sgd-update-row-mini $W-e tok ge $lr))
          (set! ti (+ ti 1))
          (recur 0)
        )
      )
    )

    ; W-proj 업데이트: 모든 행 (MINI-VOCAB개)
    (define ri 0)
    (loop [[$_ 0]]
      (if (>= ri MINI-VOCAB) 0
        (
          (define gp (grad-proj-row $toks $W-e $blks $Wp $bp $target ri $h))
          (set! $Wp (sgd-update-proj-row $Wp ri gp $lr))
          (set! ri (+ ri 1))
          (recur 0)
        )
      )
    )

    [$W-e $Wp]
  )
]

; ─── Phase 3 학습 ───────────────────────────────────────────────
(define MINI-LR     1.0)
(define MINI-H      0.001)
(define MINI-STEPS  20)

(define mini-We  (rand-vec (* MINI-VOCAB MINI-D) 0.1))
(define mini-blk [(make-block MINI-D MINI-DH MINI-FFN MINI-HEADS MINI-SEQ)])
(define mini-Wp  (rand-vec (* MINI-VOCAB MINI-D) 0.1))
(define mini-bp  (zeros MINI-VOCAB))

(define mini-loss0 (ce-loss-mini MINI-TOKENS mini-We mini-blk mini-Wp mini-bp MINI-TARGET))
(println "")
(println (str "Phase3 초기 loss: " mini-loss0))

; 학습 루프
(define mini-We-t mini-We)
(define mini-Wp-t mini-Wp)
(define ms 0)
(loop [[$_ 0]]
  (if (>= ms MINI-STEPS) 0
    (
      (define result (train-step-full MINI-TOKENS mini-We-t mini-blk mini-Wp-t mini-bp MINI-TARGET MINI-LR MINI-H))
      (set! mini-We-t (get result 0))
      (set! mini-Wp-t (get result 1))
      (set! ms (+ ms 1))
      (recur 0)
    )
  )
)

(define mini-loss-final (ce-loss-mini MINI-TOKENS mini-We-t mini-blk mini-Wp-t mini-bp MINI-TARGET))
(define mini-improved (< mini-loss-final mini-loss0))
(println (str "Phase3 최종 loss: " mini-loss-final))
(println (str "Phase3 loss 감소: " mini-improved))
(println "=== Phase 3 완료 ===")
