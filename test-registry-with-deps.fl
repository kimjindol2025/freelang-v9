; Phase 7 Stage 4: Test Registry with Dependencies
; 메모리 기반 패키지 저장소 (의존성 포함)

[FUNC get_packages :params []
  :body {
    :lodash {
      :id "lodash"
      :name "lodash"
      :description "A utility library for common programming tasks"
      :downloads 10000000
      :stars 52000
      :versions [
        { :version "4.17.21" :published_at "2021-05-13" :checksum "sha256:22_22" :dependencies {} }
      ]
    }
    :express {
      :id "express"
      :name "express"
      :description "Fast, unopinionated web framework"
      :downloads 20000000
      :stars 56000
      :versions [
        { :version "4.17.1" :published_at "2021-05-13" :checksum "sha256:22_22" :dependencies {} }
      ]
    }
    :app-utils {
      :id "app-utils"
      :name "app-utils"
      :description "Application utilities that depend on lodash"
      :downloads 50000
      :stars 150
      :versions [
        {
          :version "1.0.0"
          :published_at "2024-01-01"
          :checksum "sha256:23_23"
          :dependencies {
            :lodash "4.17.21"
          }
        }
      ]
    }
    :web-app {
      :id "web-app"
      :name "web-app"
      :description "Web app that depends on express and app-utils"
      :downloads 10000
      :stars 50
      :versions [
        {
          :version "2.0.0"
          :published_at "2024-02-01"
          :checksum "sha256:21_21"
          :dependencies {
            :express "4.17.1"
            :app-utils "1.0.0"
          }
        }
      ]
    }
  }
]

[FUNC handle_registry_packages :params [$req]
  :body (do
    (let [
        [$rid (get $req "request_id")]
        [$query (get $req "query")]
        [$method (get $req "method")]
        [$packages (get_packages)]
        [$name (get $query "name")]
        [$version (get $query "version")]
      ]
      (do
        (if (= $method "GET")
          (do
            (if (not $name)
              (server_status 200 {
                :success true
                :count 4
                :packages $packages
              })
              (do
                (let [
                    [$pkg (get $packages $name)]
                  ]
                  (if $pkg
                    (server_status 200 {
                      :success true
                      :package $pkg
                      :version (if $version $version "latest")
                    })
                    (server_status 404 {
                      :success false
                      :message (concat "Package " $name " not found")
                      :code "E_PACKAGE_NOT_FOUND"
                    })
                  )
                )
              )
            )
          )
          (server_status 405 {
            :success false
            :code "E_METHOD_NOT_ALLOWED"
          })
        )
      )
    )
  )
]

(println "🚀 Starting v9 Test Registry (with Dependencies) on port 4000...")

(server_get "/registry/packages" "handle_registry_packages")
(server_get "/registry/packages/:name" "handle_registry_packages")

(let [[$msg (server_start 4000)]]
  (println $msg)
)

(println "📖 Registry with dependencies ready:")
(println "  lodash@4.17.21          (no dependencies)")
(println "  express@4.17.1          (no dependencies)")
(println "  app-utils@1.0.0         (depends on lodash@4.17.21)")
(println "  web-app@2.0.0           (depends on express@4.17.1 + app-utils@1.0.0)")
(println "✅ Test Registry ready (port 4000). Press Ctrl+C to stop.")
