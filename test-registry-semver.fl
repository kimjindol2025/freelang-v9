; Phase 7 Stage 5: Test Registry with Semver Versions
; Multiple versions to test ^, ~, latest resolution

[FUNC get_packages :params []
  :body {
    :semver-lib {
      :id "semver-lib"
      :name "semver-lib"
      :description "Library with multiple versions for semver testing"
      :downloads 10000
      :stars 100
      :versions [
        { :version "1.0.0" :published_at "2024-01-01" :checksum "sha256:24_24" :dependencies {} }
        { :version "1.1.0" :published_at "2024-02-01" :checksum "sha256:24_24" :dependencies {} }
        { :version "1.2.0" :published_at "2024-03-01" :checksum "sha256:24_24" :dependencies {} }
        { :version "2.0.0" :published_at "2024-04-01" :checksum "sha256:24_24" :dependencies {} }
        { :version "2.1.0" :published_at "2024-05-01" :checksum "sha256:24_24" :dependencies {} }
      ]
    }
  }
]

[FUNC handle_registry_packages :params [$req]
  :body (do
    (let [
        [$query (get $req "query")]
        [$method (get $req "method")]
        [$packages (get_packages)]
        [$name (get $query "name")]
      ]
      (if (= $method "GET")
        (if (not $name)
          (server_status 200 { :success true :packages $packages })
          (let [[$pkg (get $packages $name)]]
            (if $pkg
              (server_status 200 { :success true :package $pkg })
              (server_status 404 { :success false :message "Not found" }))))
        (server_status 405 { :success false }))))
]

(server_get "/registry/packages" "handle_registry_packages")
(server_start 4002)
