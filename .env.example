# FreeLang v9 환경설정 예제
# 사용법: 이 파일을 복사해서 .env로 만들고 값을 설정하세요
# cp .env.example .env

# ═══════════════════════════════════════════
# Blog Server Configuration
# ═══════════════════════════════════════════

# Blog API 키 (production: 반드시 설정)
BLOG_API_KEY=your-secure-api-key-here-change-in-production

# Blog API URL
BLOG_API_URL=http://localhost:30112/api/posts

# ═══════════════════════════════════════════
# Node.js Environment
# ═══════════════════════════════════════════

# development | production
NODE_ENV=development

# Port for blog server (optional)
BLOG_PORT=30111

# ═══════════════════════════════════════════
# Security
# ═══════════════════════════════════════════

# JWT 시크릿 (필요시)
JWT_SECRET=your-jwt-secret-key

# Database 경로
DB_PATH=./data/freelang.db
