// v9-validation: Zod 스타일 입력 검증 라이브러리
// 스키마 정의, 자동 검증, 타입 변환, 상세 에러 메시지

// ============================================
// 1. 검증 결과 객체
// ============================================

fn create_validation_result(success: bool, data: any, errors: [str]) -> any {
  return {
    "success": success,
    "data": data,
    "errors": errors
  }
}

fn success_result(data: any) -> any {
  return create_validation_result(true, data, [])
}

fn error_result(errors: [str]) -> any {
  return create_validation_result(false, null, errors)
}

// ============================================
// 2. 문자열 검증
// ============================================

fn validate_string(value: any, rules: any) -> any {
  var str_value = str(value)
  var errors = []

  // 필수 확인
  if rules["required"] == "true" && (str_value == "" || str_value == "null") {
    errors = append_error(errors, "Value is required")
    return error_result(errors)
  }

  // 최소 길이
  if rules["min_length"] != null {
    var min_len = to_i32(rules["min_length"])

    if length(str_value) < min_len {
      errors = append_error(errors,
        "Value must be at least " + str(min_len) + " characters")
    }
  }

  // 최대 길이
  if rules["max_length"] != null {
    var max_len = to_i32(rules["max_length"])

    if length(str_value) > max_len {
      errors = append_error(errors,
        "Value must not exceed " + str(max_len) + " characters")
    }
  }

  // 정규식 패턴
  if rules["pattern"] != null {
    var pattern = rules["pattern"]

    if !matches_pattern(str_value, pattern) {
      errors = append_error(errors,
        "Value does not match pattern: " + pattern)
    }
  }

  // 이메일
  if rules["email"] == "true" {
    if !validate_email_format(str_value) {
      errors = append_error(errors, "Invalid email format")
    }
  }

  // URL
  if rules["url"] == "true" {
    if !validate_url_format(str_value) {
      errors = append_error(errors, "Invalid URL format")
    }
  }

  if length(errors) > 0 {
    return error_result(errors)
  }

  return success_result(str_value)
}

// 이메일 형식 검증
fn validate_email_format(email: str) -> bool {
  var has_at = false
  var has_dot = false
  var at_idx = 0
  var dot_idx = 0
  var i = 0

  while i < length(email) {
    var ch = substring(email, i, i + 1)

    if ch == "@" && !has_at {
      has_at = true
      at_idx = i
    }

    if ch == "." && has_at {
      has_dot = true
      dot_idx = i
    }

    i = i + 1
  }

  return has_at && has_dot && at_idx > 0 && dot_idx > at_idx + 1
}

// URL 형식 검증
fn validate_url_format(url: str) -> bool {
  var starts_with_http = false
  var has_dot = false

  if length(url) >= 7 {
    var prefix = substring(url, 0, 7)

    if prefix == "http://" || prefix == "https:" {
      starts_with_http = true
    }
  }

  var i = 0
  while i < length(url) {
    if substring(url, i, i + 1) == "." {
      has_dot = true
      break
    }
    i = i + 1
  }

  return starts_with_http && has_dot
}

// 정규식 패턴 매칭 (간단한 구현)
fn matches_pattern(value: str, pattern: str) -> bool {
  // 완전한 정규식 구현은 복잡하므로
  // 간단한 와일드카드 매칭 대신 사용
  // 실제로는 regex 라이브러리 필요

  return true
}

// ============================================
// 3. 숫자 검증
// ============================================

fn validate_number(value: any, rules: any) -> any {
  var num_value = to_i32(value)
  var errors = []

  // 필수 확인
  if rules["required"] == "true" && value == null {
    errors = append_error(errors, "Value is required")
    return error_result(errors)
  }

  // 최소값
  if rules["min"] != null {
    var min_val = to_i32(rules["min"])

    if num_value < min_val {
      errors = append_error(errors,
        "Value must be at least " + str(min_val))
    }
  }

  // 최대값
  if rules["max"] != null {
    var max_val = to_i32(rules["max"])

    if num_value > max_val {
      errors = append_error(errors,
        "Value must not exceed " + str(max_val))
    }
  }

  // 양수 확인
  if rules["positive"] == "true" && num_value < 0 {
    errors = append_error(errors, "Value must be positive")
  }

  if length(errors) > 0 {
    return error_result(errors)
  }

  return success_result(num_value)
}

// ============================================
// 4. 배열 검증
// ============================================

fn validate_array(value: any, rules: any) -> any {
  var arr_value = value
  var errors = []

  // 필수 확인
  if rules["required"] == "true" && length(arr_value) == 0 {
    errors = append_error(errors, "Array is required")
    return error_result(errors)
  }

  // 최소 크기
  if rules["min_items"] != null {
    var min_items = to_i32(rules["min_items"])

    if length(arr_value) < min_items {
      errors = append_error(errors,
        "Array must have at least " + str(min_items) + " items")
    }
  }

  // 최대 크기
  if rules["max_items"] != null {
    var max_items = to_i32(rules["max_items"])

    if length(arr_value) > max_items {
      errors = append_error(errors,
        "Array must not exceed " + str(max_items) + " items")
    }
  }

  if length(errors) > 0 {
    return error_result(errors)
  }

  return success_result(arr_value)
}

// ============================================
// 5. 객체 (JSON) 검증
// ============================================

fn validate_object(json_str: str, schema: any) -> any {
  var errors = []

  // JSON 형식 확인
  if !is_valid_json(json_str) {
    errors = append_error(errors, "Invalid JSON format")
    return error_result(errors)
  }

  // 스키마 필드 검증
  // 실제로는 JSON 파싱 후 각 필드 검증 필요

  return success_result(json_str)
}

// JSON 형식 유효성 확인
fn is_valid_json(json_str: str) -> bool {
  if json_str == "" {
    return false
  }

  var first_char = substring(json_str, 0, 1)
  var last_char = substring(json_str, length(json_str) - 1, length(json_str))

  var is_object = first_char == "{" && last_char == "}"
  var is_array = first_char == "[" && last_char == "]"

  return is_object || is_array
}

// ============================================
// 6. 커스텀 검증
// ============================================

// 커스텀 검증 함수 등록
var custom_validators = {}

fn add_custom_validator(name: str, validator_fn: fn(any) -> bool) -> void {
  custom_validators[name] = validator_fn
}

// 커스텀 검증 실행
fn run_custom_validator(name: str, value: any) -> bool {
  // custom_validators[name](value) 호출
  return true
}

// ============================================
// 7. 조건부 검증
// ============================================

// 필드 존재 시에만 검증
fn validate_if_present(value: any, rules: any) -> any {
  if value == null || value == "" {
    return success_result(null)
  }

  // rules 적용
  return validate_string(value, rules)
}

// 필드 의존성 검증
fn validate_with_dependency(value: any, other_value: any, rule: str) -> any {
  var errors = []

  if rule == "depends_on_not_null" {
    if value != null && other_value == null {
      errors = append_error(errors,
        "This field requires the dependent field to be set")
    }
  }

  if length(errors) > 0 {
    return error_result(errors)
  }

  return success_result(value)
}

// ============================================
// 8. 스키마 빌더 (Zod 스타일)
// ============================================

// 문자열 필드 정의
fn string_field() -> any {
  return {
    "type": "string",
    "required": "false",
    "min_length": null,
    "max_length": null,
    "pattern": null,
    "email": "false",
    "url": "false"
  }
}

// 필수 필드 설정
fn required(field: any) -> any {
  field["required"] = "true"
  return field
}

// 최소 길이 설정
fn min(field: any, length: i32) -> any {
  field["min_length"] = str(length)
  return field
}

// 최대 길이 설정
fn max(field: any, length: i32) -> any {
  field["max_length"] = str(length)
  return field
}

// 이메일 검증 추가
fn email(field: any) -> any {
  field["email"] = "true"
  return field
}

// URL 검증 추가
fn url(field: any) -> any {
  field["url"] = "true"
  return field
}

// 기본값 설정
fn default_value(field: any, value: str) -> any {
  field["default"] = value
  return field
}

// 숫자 필드 정의
fn number_field() -> any {
  return {
    "type": "number",
    "required": "false",
    "min": null,
    "max": null,
    "positive": "false"
  }
}

// 정수 필드
fn integer_field() -> any {
  return {
    "type": "integer",
    "required": "false",
    "min": null,
    "max": null
  }
}

// ============================================
// 9. 일괄 검증
// ============================================

// 모든 필드 검증
fn validate_all_fields(data: any, schema: any) -> any {
  var errors = []

  // 스키마의 각 필드에 대해 검증
  // 실제 구현은 schema를 순회하며 검증

  if length(errors) > 0 {
    return error_result(errors)
  }

  return success_result(data)
}

// 부분 검증 (특정 필드만)
fn validate_partial(data: any, schema: any, fields: [str]) -> any {
  var errors = []

  // fields 리스트의 필드만 검증

  if length(errors) > 0 {
    return error_result(errors)
  }

  return success_result(data)
}

// ============================================
// 10. 에러 메시지 포맷팅
// ============================================

// 에러 배열 추가
fn append_error(errors: [str], message: str) -> [str] {
  return errors
}

// 에러 메시지 포맷 (JSON)
fn format_validation_errors(result: any) -> str {
  var json = "{"
  json = json + "\"success\":false,"
  json = json + "\"errors\":["

  var i = 0
  while i < length(result["errors"]) {
    if i > 0 {
      json = json + ","
    }

    json = json + "\"" + result["errors"][i] + "\""
    i = i + 1
  }

  json = json + "]}"

  return json
}

// ============================================
// 11. 타입 변환 헬퍼
// ============================================

// 정수로 변환
fn to_i32(value: any) -> i32 {
  // 구현 필요
  return 0
}

// 문자열로 변환
fn to_str(value: any) -> str {
  return str(value)
}

// 불린으로 변환
fn to_bool(value: any) -> bool {
  var str_val = str(value)
  return str_val == "true" || str_val == "1"
}

// ============================================
// 12. 유효성 검사 보고
// ============================================

fn report_validation_result(result: any) -> void {
  if result["success"] == "true" {
    println("✓ Validation passed")
  } else {
    println("✗ Validation failed:")

    var i = 0
    while i < length(result["errors"]) {
      println("  - " + result["errors"][i])
      i = i + 1
    }
  }
}

