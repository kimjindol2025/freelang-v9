// FreeLang v9 Collections 라이브러리 모듈 테스트
//
// **목적**: HashMap, HashSet 검증 (실제 동작 확인)
// **테스트 범위**: HashMap (put/get/contains/remove), HashSet (dedup 검증)
// **핵심**: HashSet 중복 add 시 size 변화 없음 (Deduplication)

struct TestCase {
    name: str
    passed: bool
    message: str
}

struct TestSuite {
    name: str
    cases: [TestCase]
    pass_count: i32
    fail_count: i32
}

fn assert_equal(actual: str, expected: str, test_name: str) -> TestCase {
    var passed = (actual == expected)
    var msg = ""
    if !passed {
        msg = "Expected: '" + expected + "', Got: '" + actual + "'"
    }
    TestCase { name: test_name, passed: passed, message: msg }
}

fn assert_true(condition: bool, test_name: str) -> TestCase {
    TestCase { name: test_name, passed: condition, message: "" }
}

fn assert_number(actual: i32, expected: i32, test_name: str) -> TestCase {
    var passed = (actual == expected)
    var msg = ""
    if !passed {
        msg = "Expected: " + str(expected) + ", Got: " + str(actual)
    }
    TestCase { name: test_name, passed: passed, message: msg }
}

fn test_suite_add_case(suite: TestSuite, case: TestCase) -> TestSuite {
    suite.cases.push(case)
    if case.passed {
        suite.pass_count = suite.pass_count + 1
    } else {
        suite.fail_count = suite.fail_count + 1
    }
    suite
}

fn test_suite_report(suite: TestSuite) -> str {
    var total = suite.pass_count + suite.fail_count
    println("═════════════════════════════════════════")
    println("  " + suite.name)
    println("═════════════════════════════════════════")
    println("")

    var i: i32 = 0
    while i < length(suite.cases) {
        var case = suite.cases[i]
        if case.passed {
            println("  ✅ " + case.name)
        } else {
            println("  ❌ " + case.name)
            println("     " + case.message)
        }
        i = i + 1
    }

    println("")
    println("  Results: " + str(suite.pass_count) + " / " + str(total) + " passed")
    println("")

    suite.name
}

// ============================================================
// HashMap 구조체 및 함수 (시뮬레이션)
// ============================================================

struct HashMap {
    keys: [str]
    values: [str]
    size: i32
}

fn hashmap_new() -> HashMap {
    HashMap { keys: [], values: [], size: 0 }
}

fn hashmap_put(map: HashMap, key: str, value: str) -> HashMap {
    var i: i32 = 0
    var found = false

    while i < length(map.keys) {
        if map.keys[i] == key {
            map.values[i] = value
            found = true
            break
        }
        i = i + 1
    }

    if !found {
        map.keys.push(key)
        map.values.push(value)
        map.size = map.size + 1
    }

    map
}

fn hashmap_get(map: HashMap, key: str) -> str {
    var i: i32 = 0
    while i < length(map.keys) {
        if map.keys[i] == key {
            return map.values[i]
        }
        i = i + 1
    }
    ""
}

fn hashmap_contains(map: HashMap, key: str) -> bool {
    var i: i32 = 0
    while i < length(map.keys) {
        if map.keys[i] == key {
            return true
        }
        i = i + 1
    }
    false
}

fn hashmap_remove(map: HashMap, key: str) -> HashMap {
    var i: i32 = 0
    var found_idx: i32 = -1

    while i < length(map.keys) {
        if map.keys[i] == key {
            found_idx = i
            break
        }
        i = i + 1
    }

    if found_idx >= 0 {
        ;; 요소 제거 (간단한 시뮬레이션: 배열 재구성)
        var new_keys: [str] = []
        var new_values: [str] = []
        var j: i32 = 0

        while j < length(map.keys) {
            if j != found_idx {
                new_keys.push(map.keys[j])
                new_values.push(map.values[j])
            }
            j = j + 1
        }

        map.keys = new_keys
        map.values = new_values
        map.size = map.size - 1
    }

    map
}

// ============================================================
// HashSet 구조체 및 함수 (시뮬레이션, Dedup 포함)
// ============================================================

struct HashSet {
    elements: [str]
    size: i32
}

fn hashset_new() -> HashSet {
    HashSet { elements: [], size: 0 }
}

fn hashset_add(set: HashSet, element: str) -> HashSet {
    ;; 중복 확인: 이미 있으면 추가 안 함
    var i: i32 = 0
    var found = false

    while i < length(set.elements) {
        if set.elements[i] == element {
            found = true
            break
        }
        i = i + 1
    }

    if !found {
        set.elements.push(element)
        set.size = set.size + 1
    }

    set
}

fn hashset_contains(set: HashSet, element: str) -> bool {
    var i: i32 = 0
    while i < length(set.elements) {
        if set.elements[i] == element {
            return true
        }
        i = i + 1
    }
    false
}

fn hashset_remove(set: HashSet, element: str) -> HashSet {
    var i: i32 = 0
    var found_idx: i32 = -1

    while i < length(set.elements) {
        if set.elements[i] == element {
            found_idx = i
            break
        }
        i = i + 1
    }

    if found_idx >= 0 {
        var new_elements: [str] = []
        var j: i32 = 0

        while j < length(set.elements) {
            if j != found_idx {
                new_elements.push(set.elements[j])
            }
            j = j + 1
        }

        set.elements = new_elements
        set.size = set.size - 1
    }

    set
}

// ============================================================
// HashMap 테스트
// ============================================================

fn test_hashmap_basic() -> TestSuite {
    var suite = TestSuite { name: "HashMap Basic Tests", cases: [], pass_count: 0, fail_count: 0 }

    ;; put → size 증가
    var map = hashmap_new()
    map = hashmap_put(map, "age", "25")
    suite = test_suite_add_case(suite, assert_number(map.size, 1, "put increases size"))

    ;; get → 올바른 값
    var age = hashmap_get(map, "age")
    suite = test_suite_add_case(suite, assert_equal(age, "25", "get retrieves value"))

    ;; contains → true
    var has_age = hashmap_contains(map, "age")
    suite = test_suite_add_case(suite, assert_true(has_age, "contains finds key"))

    ;; contains → false (없는 키)
    var has_name = hashmap_contains(map, "name")
    suite = test_suite_add_case(suite, assert_true(!has_name, "contains returns false for missing key"))

    suite
}

fn test_hashmap_update_remove() -> TestSuite {
    var suite = TestSuite { name: "HashMap Update/Remove Tests", cases: [], pass_count: 0, fail_count: 0 }

    var map = hashmap_new()
    map = hashmap_put(map, "name", "Alice")
    map = hashmap_put(map, "age", "25")

    ;; 중복 put → 덮어쓰기 (size 변화 없음)
    map = hashmap_put(map, "name", "Bob")
    suite = test_suite_add_case(suite, assert_number(map.size, 2, "duplicate put doesn't increase size"))

    var name = hashmap_get(map, "name")
    suite = test_suite_add_case(suite, assert_equal(name, "Bob", "duplicate put overwrites value"))

    ;; remove → size 감소
    map = hashmap_remove(map, "name")
    suite = test_suite_add_case(suite, assert_number(map.size, 1, "remove decreases size"))

    var removed = hashmap_contains(map, "name")
    suite = test_suite_add_case(suite, assert_true(!removed, "remove deletes key"))

    suite
}

// ============================================================
// HashSet 테스트 (중복 제거 핵심 검증)
// ============================================================

fn test_hashset_dedup() -> TestSuite {
    var suite = TestSuite { name: "HashSet Deduplication Tests", cases: [], pass_count: 0, fail_count: 0 }

    var set = hashset_new()

    ;; add "apple" → size = 1
    set = hashset_add(set, "apple")
    suite = test_suite_add_case(suite, assert_number(set.size, 1, "add increases size"))

    ;; add "apple" 중복 → size = 1 (변화 없음) ← 핵심 검증!
    set = hashset_add(set, "apple")
    suite = test_suite_add_case(suite, assert_number(set.size, 1, "duplicate add does NOT increase size (dedup)"))

    ;; add "banana" → size = 2
    set = hashset_add(set, "banana")
    suite = test_suite_add_case(suite, assert_number(set.size, 2, "add different element increases size"))

    ;; contains "apple" → true
    var has_apple = hashset_contains(set, "apple")
    suite = test_suite_add_case(suite, assert_true(has_apple, "contains finds element"))

    ;; contains "cherry" → false
    var has_cherry = hashset_contains(set, "cherry")
    suite = test_suite_add_case(suite, assert_true(!has_cherry, "contains returns false for missing element"))

    ;; remove "apple" → size = 1
    set = hashset_remove(set, "apple")
    suite = test_suite_add_case(suite, assert_number(set.size, 1, "remove decreases size"))

    var removed = hashset_contains(set, "apple")
    suite = test_suite_add_case(suite, assert_true(!removed, "remove deletes element"))

    suite
}

// ============================================================
// 메인 테스트 실행
// ============================================================

fn main() {
    println("╔═══════════════════════════════════════════╗")
    println("║  v9 stdlib::collections 모듈 테스트     ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    ;; 테스트 1: HashMap 기본
    var suite1 = test_hashmap_basic()
    test_suite_report(suite1)

    ;; 테스트 2: HashMap 업데이트/제거
    var suite2 = test_hashmap_update_remove()
    test_suite_report(suite2)

    ;; 테스트 3: HashSet 중복 제거 (핵심!)
    var suite3 = test_hashset_dedup()
    test_suite_report(suite3)

    println("✅ Collections 모듈 테스트 완료!")
    println("")
}
