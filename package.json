{
  "name": "freelang-v9",
  "version": "9.2.0",
  "description": "FreeLang v9 — AI-Native Programming Language. AI를 위한, AI에 의한, AI가 쓰고 싶은 언어.",
  "keywords": [
    "ai",
    "language",
    "freelang",
    "s-expression",
    "ai-native",
    "claude",
    "agent",
    "llm",
    "reasoning",
    "chain-of-thought"
  ],
  "author": "Claude Code (Anthropic)",
  "license": "MIT",
  "homepage": "https://gogs.dclub.kr/kim/freelang-v9",
  "repository": {
    "type": "git",
    "url": "https://gogs.dclub.kr/kim/freelang-v9.git"
  },
  "bugs": {
    "url": "https://gogs.dclub.kr/kim/freelang-v9/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "v9": "dist/cli.js",
    "freelang": "dist/cli.js"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./interpreter": {
      "require": "./dist/interpreter.js"
    },
    "./parser": {
      "require": "./dist/parser.js"
    }
  },
  "files": [
    "dist",
    "stdlib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project .config/tsconfig.json",
    "v9:build": "ts-node vpm/v9-build-entry.ts",
    "v9:install": "ts-node vpm/v9-pm-entry.ts install",
    "v9:run": "ts-node vpm/v9-run-entry.ts",
    "test": "jest --config .config/jest.config.js --passWithNoTests",
    "test:watch": "jest --config .config/jest.config.js --watch",
    "test:coverage": "jest --config .config/jest.config.js --coverage",
    "test:ci": "jest --config .config/jest.config.js --ci --coverage --maxWorkers=2",
    "test:e2e": "ts-node src/test-full-stack.ts",
    "test-legacy": "ts-node src/test-full-stack.ts",
    "test-parser": "ts-node src/test-parser.ts",
    "test-interpreter": "ts-node src/test-interpreter.ts",
    "benchmark": "node scripts/benchmark.js",
    "start": "ts-node src/http-server-runner.ts",
    "server": "ts-node src/http-server-runner.ts",
    "freelang": "ts-node src/cli.ts",
    "fl": "ts-node src/cli.ts",
    "repl": "ts-node src/cli.ts repl"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/ws": "^8.18.1",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "ws": "^8.20.0"
  }
}
