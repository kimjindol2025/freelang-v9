(defn piano-transcribe [audio sr]
  "Transcribe piano music to note sequence"
  {:notes []
   :times []})

(defn multi-pitch [spectrogram sr]
  "Estimate multiple pitches simultaneously"
  (vec (repeat 10 0.0)))

(defn onset-offset [signal sr]
  "Detect note onsets and offsets"
  {:onsets []
   :offsets []})

(print "✓ Music Transcription (Phase 319) loaded")
