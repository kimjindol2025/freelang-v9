; Phase 197: Profiling
(defn measure-time [f]
  "Measure execution time"
  (let [start (System/nanoTime)
        result (f)
        end (System/nanoTime)]
    {:result result :time (- end start)}))

(defn hot-path-analysis [calls]
  "Find hot paths"
  (let [counts (frequencies calls)
        sorted (sort-by second (fn [a b] (> a b)) counts)]
    (take 10 (map first sorted))))

(print "✓ Profiling (Phase 197) loaded")
