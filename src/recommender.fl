(defn matrix-factor [user-item-matrix num-factors regularization]
  "Matrix factorization for recommendations"
  {:user-factors (vec (repeat 100 []))
   :item-factors (vec (repeat 100 []))})

(defn als [user-item-matrix num-factors iterations]
  "Alternating Least Squares for recommendations"
  {:user-factors []
   :item-factors []})

(defn ncf [user-features item-features num-layers]
  "Neural Collaborative Filtering"
  {:predictions []})

