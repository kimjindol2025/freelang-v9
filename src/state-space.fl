(defn kalman-filter [ts F Q R x0 P0]
  "Kalman filter"
  {:estimates []
   :covariances []})

(defn kalman-smooth [ts F Q R]
  "Rauch-Tung-Striebel smoother"
  {:smoothed-estimates []
   :smoothed-covariances []})

(defn em-ssm [ts max-iter]
