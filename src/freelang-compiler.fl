; FreeLang v9: Compiler (self-hosting)
; FreeLang source string → JavaScript source string
;
; 파이프라인: src → lex → parse → gen-js → JS string

[FUNC compile :params [$src]
  :body (
    (let [[tokens (lex $src)]]
      (let [[ast (parse $tokens)]]
        (gen-js $ast)
      )
    )
  )
]

(export compile)
