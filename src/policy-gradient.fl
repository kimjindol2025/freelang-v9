; Phase 212: Policy Gradient Methods
(defn policy-gradient-loss [log-prob reward baseline]
  "Policy gradient loss"
  (let [advantage (- reward baseline)
        loss (* (- log-prob) advantage)]
    loss))

(defn actor-critic [state action reward next-state actor-lr critic-lr]
  "Actor-Critic algorithm"
  {:actor-loss (policy-gradient-loss 0.5 reward 0)
   :critic-loss (* 0.5 (Math/pow (- reward 0) 2))})

(print "✓ Policy Gradient (Phase 212) loaded")
